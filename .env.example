# Copy this file to `.env.local` and fill in only the provider(s) you use.

# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_ENDPOINT=

# Vertex AI / Gemini
GENAI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=False

# vLLM local server
VLLM_PORT=8000

# LiteLLM proxy
LITELLM_API_KEY=
LITELLM_API_BASE=http://localhost:4000/v1
ANTHROPIC_API_KEY=
